---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/site/ContactForm.astro";
import { site } from "@/data/site";
import {
  MapPin,
  Mail,
  Phone,
  Globe,
  MessageSquareText,
  Building2,
  ArrowRight,
  Clock,
  ShieldCheck,
} from "lucide-react";
import PageHero from "@/components/site/PageHero.astro";

const primaryPhone = site.phones?.[0] ?? "";
const phoneHref = primaryPhone
  ? `tel:${primaryPhone.replaceAll("-", "").replaceAll(" ", "")}`
  : "/contact";

const contactCards = [
  {
    label: "Email",
    value: site.email,
    href: `mailto:${site.email}`,
    icon: Mail,
  },
  ...site.phones.map((phone) => ({
    label: "Phone",
    value: phone,
    href: `tel:${phone.replaceAll("-", "").replaceAll(" ", "")}`,
    icon: Phone,
  }))
];
---

<BaseLayout
  title="Contact"
  description="Contact Sai Feed Equipment through phone, email, website or inquiry form."
>
  <PageHero
    eyebrow="Contact"
    title={`Send inquiry to ${site.name}`}
    description={site.backCoverTagline}
  />

  <section class="section-shell bg-background py-16 sm:py-20">
    <div class="container-page grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <aside class="grid content-start gap-5" data-stagger>
        <div
          class="surface-card group rounded-[2rem] p-6 transition duration-300 hover:-translate-y-1 hover:border-brand-green hover:shadow-xl"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green"
            >
              <Building2 className="size-6" />
            </div>

            <div>
              <p
                class="text-sm font-black uppercase tracking-[0.22em] text-brand-green"
              >
                Business Address
              </p>
              <h2 class="mt-2 text-2xl font-black text-brand-navy">
                Sai Feed Equipment
              </h2>
            </div>
          </div>

          <div class="mt-5 grid gap-3 text-base leading-7 text-brand-muted">
            {
              site.addressLines.map((line) => (
                <div class="flex gap-3">
                  <MapPin className="mt-1 size-4 shrink-0 text-brand-green" />
                  <p>{line}</p>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="surface-card rounded-[2rem] p-6"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green"
            >
              <Phone className="size-6" />
            </div>

            <div>
              <p
                class="text-sm font-black uppercase tracking-[0.22em] text-brand-green"
              >
                Contact Details
              </p>
              <h2 class="mt-2 text-2xl font-black text-brand-navy">
                Reach the team
              </h2>
            </div>
          </div>

          <div class="mt-6 grid gap-3">
            {
              contactCards.map((item) => {
                const Icon = item.icon;

                return (
                  <a
                    href={item.href}
                    target={item.label === "Website" ? "_blank" : undefined}
                    rel={item.label === "Website" ? "noreferrer" : undefined}
                    class="group flex min-h-14 items-center gap-4 rounded-2xl border border-brand-border bg-white px-4 py-3 transition duration-300 hover:-translate-y-0.5 hover:border-brand-green hover:shadow-md"
                  >
                    <span class="flex size-10 shrink-0 items-center justify-center rounded-xl bg-brand-green/10 text-brand-green transition duration-300 group-hover:bg-brand-green group-hover:text-white">
                      <Icon className="size-5" />
                    </span>

                    <span class="min-w-0 flex-1">
                      <span class="block text-xs font-black uppercase tracking-[0.18em] text-brand-muted">
                        {item.label}
                      </span>
                      <span class="mt-1 block break-words text-sm font-bold text-brand-navy transition group-hover:text-brand-green">
                        {item.value}
                      </span>
                    </span>

                    <ArrowRight className="size-4 shrink-0 text-brand-green opacity-0 transition duration-300 group-hover:translate-x-1 group-hover:opacity-100" />
                  </a>
                );
              })
            }
          </div>
        </div>
      </aside>

      <div id="inquiry-form" class="scroll-mt-28" data-reveal="right">
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
