---
import BaseLayout from "@/layouts/BaseLayout.astro";

const products = [
  "Pellet Mill",
  "Hammer Mill",
  "Cooler",
  "Ribbon Mixer",
  "Paddle Mixer",
  "Crumber",
];

const solutions = [
  {
    title: "Animal Feed Plant",
    text: "Complete feed plant solutions for efficient production, processing, mixing, pelleting and material handling.",
    href: "/solutions/animal-feed-plant",
  },
  {
    title: "Biomass / Wood Plant",
    text: "Industrial plant solutions for biomass and wood pellet processing applications.",
    href: "/solutions/biomass-wood-plant",
  },
  {
    title: "Pellet Plants",
    text: "Pellet production systems with machinery, automation and production workflow support.",
    href: "/solutions/pellet-plants",
  },
];

const stats = [
  { value: "11+", label: "Product Categories" },
  { value: "3", label: "Plant Solutions" },
  { value: "100%", label: "Static & Fast" },
];
---

<BaseLayout
  title="Industrial Feed Plant Machinery"
  description="Sai Feed Equipment offers feed plant machinery, pellet plants, biomass plant solutions, automation, dies, rolls, and industrial equipment."
>
  <section class="relative overflow-hidden bg-brand-navy text-white">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute -left-20 top-20 size-80 rounded-full bg-brand-green blur-3xl"></div>
      <div class="absolute bottom-0 right-0 size-96 rounded-full bg-brand-steel blur-3xl"></div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[size:48px_48px]"
      >
      </div>
    </div>

    <div
      class="container-page relative grid min-h-[calc(100svh-4rem)] items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:py-20"
    >
      <div>
        <p
          class="mb-5 inline-flex rounded-full border border-brand-green/40 bg-brand-green/10 px-4 py-2 text-sm font-bold text-brand-green"
        >
          Feed Plant • Pellet Plant • Automation
        </p>

        <h1 class="max-w-4xl text-4xl font-black tracking-tight sm:text-5xl lg:text-6xl">
          Industrial Feed Equipment Built for Reliable Production
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-8 text-white/75 sm:text-lg">
          Professional machinery and plant solutions for animal feed, biomass, pellet production,
          material handling, automation, dies and rolls.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-green px-7 text-sm font-black text-white shadow-xl shadow-brand-green/20 transition hover:bg-brand-green-dark"
          >
            Send Inquiry
          </a>

          <a
            href="/products/pellet-mill"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/20 px-7 text-sm font-black text-white transition hover:bg-white/10"
          >
            View Products
          </a>
        </div>

        <div class="mt-10 grid max-w-xl grid-cols-3 gap-3">
          {
            stats.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                <div class="text-2xl font-black text-white">{item.value}</div>
                <div class="mt-1 text-xs font-medium leading-5 text-white/60">{item.label}</div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-2xl backdrop-blur">
        <div class="rounded-[1.5rem] bg-brand-card p-5 text-brand-navy">
          <div
            class="flex aspect-[4/3] items-center justify-center rounded-[1.25rem] border-2 border-dashed border-brand-border bg-white/50 text-center"
          >
            <div class="px-6">
              <p class="text-xl font-black">Machinery Visual</p>
              <p class="mt-2 text-sm leading-6 text-brand-muted">
                Add product or brochure machinery image here.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 sm:py-20">
    <div class="container-page">
      <div class="max-w-2xl">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-brand-green">
          Company Overview
        </p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-navy sm:text-4xl">
          Feed plant machinery and industrial plant solutions
        </h2>
        <p class="mt-5 text-base leading-8 text-brand-muted">
          Sai Feed Equipment provides machinery and plant solution support for feed production,
          pellet plants, biomass processing, automation and related industrial equipment needs.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <div class="rounded-3xl border border-brand-border bg-card p-6 shadow-sm">
          <div class="text-3xl">⚙️</div>
          <h3 class="mt-5 text-xl font-black text-brand-navy">Machinery Range</h3>
          <p class="mt-3 text-sm leading-7 text-brand-muted">
            Pellet mills, hammer mills, mixers, coolers, crumblers, sieves and material handling
            equipment.
          </p>
        </div>

        <div class="rounded-3xl border border-brand-border bg-card p-6 shadow-sm">
          <div class="text-3xl">🏭</div>
          <h3 class="mt-5 text-xl font-black text-brand-navy">Plant Solutions</h3>
          <p class="mt-3 text-sm leading-7 text-brand-muted">
            Plant layouts and production solutions for animal feed, biomass, wood and pellet
            production.
          </p>
        </div>

        <div class="rounded-3xl border border-brand-border bg-card p-6 shadow-sm">
          <div class="text-3xl">📞</div>
          <h3 class="mt-5 text-xl font-black text-brand-navy">Inquiry Focused</h3>
          <p class="mt-3 text-sm leading-7 text-brand-muted">
            Clear calls, WhatsApp/contact actions and product-specific inquiry routes for business
            leads.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-card py-16 sm:py-20">
    <div class="container-page">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-black uppercase tracking-[0.25em] text-brand-green">
            Solutions
          </p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-navy sm:text-4xl">
            Complete plant solution categories
          </h2>
        </div>

        <a
          href="/solutions/animal-feed-plant"
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-brand-navy px-5 text-sm font-bold text-white transition hover:bg-brand-green"
        >
          Explore Solutions
        </a>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {
          solutions.map((solution) => (
            <a
              href={solution.href}
              class="group rounded-3xl border border-brand-border bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-brand-green hover:shadow-xl"
            >
              <div class="flex size-12 items-center justify-center rounded-2xl bg-brand-green/10 text-xl">
                🌱
              </div>
              <h3 class="mt-6 text-xl font-black text-brand-navy">{solution.title}</h3>
              <p class="mt-3 text-sm leading-7 text-brand-muted">{solution.text}</p>
              <span class="mt-6 inline-flex text-sm font-black text-brand-green">
                View Solution →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-16 sm:py-20">
    <div class="container-page">
      <div class="max-w-2xl">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-brand-green">
          Product Range
        </p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-navy sm:text-4xl">
          Machinery for feed and pellet production
        </h2>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          products.map((product) => {
            const slug = product.toLowerCase().replaceAll(" ", "-").replaceAll("/", "");
            return (
              <a
                href={`/products/${slug}`}
                class="group rounded-3xl border border-brand-border bg-card p-5 shadow-sm transition hover:-translate-y-1 hover:border-brand-green hover:shadow-xl"
              >
                <div class="aspect-[4/3] rounded-2xl bg-white p-4">
                  <div class="flex h-full items-center justify-center rounded-xl border border-dashed border-brand-border text-center">
                    <span class="text-sm font-bold text-brand-muted">Product Image</span>
                  </div>
                </div>

                <div class="mt-5 flex items-center justify-between gap-4">
                  <h3 class="text-lg font-black text-brand-navy">{product}</h3>
                  <span class="text-brand-green transition group-hover:translate-x-1">→</span>
                </div>
              </a>
            );
          })
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href="/products/pellet-mill"
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-green px-7 text-sm font-black text-white transition hover:bg-brand-green-dark"
        >
          View Product Details
        </a>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-brand-navy py-16 text-white sm:py-20">
    <div class="absolute inset-0 opacity-20">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,#00a651_0,transparent_28%),radial-gradient(circle_at_90%_10%,#1e5a78_0,transparent_24%)]"
      >
      </div>
    </div>

    <div class="container-page relative grid gap-8 lg:grid-cols-[1fr_0.7fr] lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.25em] text-brand-green">
          Get In Touch
        </p>
        <h2 class="mt-3 max-w-3xl text-3xl font-black tracking-tight sm:text-4xl">
          Need machinery or plant solution details?
        </h2>
        <p class="mt-5 max-w-2xl text-base leading-8 text-white/70">
          Share your product or plant requirement and the team can guide you with suitable
          machinery, application details and inquiry support.
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
        <a
          href="/contact"
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-green px-7 text-sm font-black text-white transition hover:bg-brand-green-dark"
        >
          Send Inquiry
        </a>

        <a
          href="tel:"
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/20 px-7 text-sm font-black text-white transition hover:bg-white/10"
        >
          Call Now
        </a>
      </div>
    </div>
  </section>
</BaseLayout>