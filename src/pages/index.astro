---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/site/SectionHeading.astro";
import ProductCard from "@/components/site/ProductCard.astro";
import SolutionCard from "@/components/site/SolutionCard.astro";
import CTASection from "@/components/site/CTASection.astro";
import OptimizedPicture from "@/components/site/OptimizedPicture.astro";
import { products } from "@/data/products";
import { solutions } from "@/data/solutions";
import { site } from "@/data/site";

const processSteps = [
  "Grinding",
  "Mixing",
  "Pelleting",
  "Cooling",
  "Crumbling",
  "Screening",
  "Auto Bagging",
];
const featuredProducts = products.slice(0, 6);
---

<BaseLayout
  title="Advanced Solution For Feed Market"
  description={site.description}
>
  <section
    class="section-shell section-shell--dark relative overflow-hidden bg-brand-navy text-white"
  >
    <div class="absolute inset-0 opacity-30">
      <div
        class="absolute -left-20 top-16 size-80 rounded-full bg-brand-green blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 right-0 size-96 rounded-full bg-brand-steel blur-3xl"
      >
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[size:48px_48px]"
      >
      </div>
    </div>

    <div
      class="container-page relative grid min-h-[calc(100svh-4rem)] items-center gap-12 py-16 lg:grid-cols-[1.02fr_0.98fr] lg:py-20"
    >
      <div data-reveal="left">
        <p
          class="mb-5 inline-flex rounded-full border border-brand-green/40 bg-brand-green/10 px-4 py-2 text-sm font-bold text-brand-green"
        >
          {site.tagline}
        </p>
        <h1
          class="max-w-4xl text-4xl font-black tracking-tight sm:text-5xl lg:text-6xl"
        >
          {site.name}
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-8 text-white/75 sm:text-lg">
          {site.description}
        </p>
        <div class="mt-10 grid max-w-2xl gap-3 sm:grid-cols-2" data-stagger>
          {
            site.manufactures.map((item) => (
              <div class="surface-card-dark group relative overflow-hidden rounded-2xl p-4 text-sm font-semibold text-white/75 transition-all duration-500 ease-out hover:-translate-y-1 hover:scale-[1.02] hover:text-white hover:shadow-2xl hover:shadow-primary/20">
                <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  <div class="absolute inset-0 bg-gradient-to-br from-white/10 via-white/5 to-transparent" />
                  <div class="absolute -right-10 -top-10 h-24 w-24 rounded-full bg-primary/20 blur-2xl transition-transform duration-700 group-hover:scale-150" />
                </div>

                <span class="relative z-10 inline-flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-primary opacity-60 transition-all duration-500 group-hover:opacity-100 group-hover:shadow-[0_0_12px_currentColor]" />
                  {item}
                </span>
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="surface-card-dark interactive-panel float-soft rounded-[2rem] p-3"
        data-reveal="right"
        data-tilt
      >
        <div class="overflow-hidden rounded-[1.5rem] bg-brand-card">
          <OptimizedPicture
            src="/images/solutions/animal-feed-plant.png"
            alt="Feed plant interior"
            width={900}
            height={675}
            loading="eager"
            fetchpriority="high"
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="aspect-[4/3] h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell bg-background py-16 sm:py-20">
    <div class="container-page">
      <SectionHeading
        eyebrow="Solutions"
        title="Plant solutions from intake to dispatch"
        description="Sai Feed Equipment presents feed plant, biomass / wood plant and pellet plant solutions with machinery, automation and process support."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3" data-stagger>
        {solutions.map((solution) => <SolutionCard solution={solution} />)}
      </div>
    </div>
  </section>

  <section class="section-shell bg-background py-16 sm:py-20">
    <div class="container-page">
      <div
        class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
      >
        <SectionHeading
          eyebrow="Products"
          title="Machinery and spare equipment"
          description="Initial product range based on the Sai Feed Equipment catalogue."
        />
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {featuredProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section-shell bg-brand-card py-16 sm:py-20">
    <div
      class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center"
    >
      <div data-reveal="left">
        <SectionHeading
          eyebrow="Automation"
          title="Recipe control and process monitoring"
          description="Computer based automation and process monitoring systems control feed formulation as per the recipe and support feed safety and traceability."
        />
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/products/plant-automation"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-green px-7 text-sm font-black text-white transition hover:bg-brand-green-dark"
            >View Automation</a
          >
          <a
            href="/solutions/pellet-plants"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-brand-border bg-white px-7 text-sm font-black text-brand-navy transition hover:border-brand-green"
            >Pellet Plants</a
          >
        </div>
      </div>
      <div
        class="surface-card interactive-panel overflow-hidden rounded-3xl"
        data-reveal="right"
        data-tilt
      >
        <OptimizedPicture
          src="/images/products/plant-automation.png"
          alt="Plant automation"
          width={900}
          height={675}
          loading="lazy"
          sizes="(max-width: 1024px) 100vw, 50vw"
          class="aspect-[4/3] h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
