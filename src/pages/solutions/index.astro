---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionHeading from "@/components/site/SectionHeading.astro";
import SolutionCard from "@/components/site/SolutionCard.astro";
import CTASection from "@/components/site/CTASection.astro";
import { solutions } from "@/data/solutions";
import {
  ArrowRight,
  Factory,
  Layers,
  Plus,
  Settings,
  Sparkles,
} from "lucide-react";

const featuredSolution = solutions[0];

const solutionStats = [
  {
    label: "Solution Scope",
    value: "Plant setup",
    icon: Factory,
  },
  {
    label: "Process Support",
    value: "Machinery",
    icon: Settings,
  },
  {
    label: "Catalogue Range",
    value: "Feed market",
    icon: Layers,
  },
];
---

<BaseLayout
  title="Solutions"
  description="Sai Feed Equipment plant solutions including animal feed plant, biomass wood plant and pellet plant solutions."
>
  <PageHero
    eyebrow="Solutions"
    title="Plant solutions from intake to dispatch"
    description="Explore Sai Feed Equipment plant solution categories for animal feed plant, biomass / wood plant and pellet plant requirements."
    image={featuredSolution?.image}
    imageAlt={featuredSolution?.imageAlt ?? "Sai Feed Equipment plant solutions"}
  />

  <section class="bg-background py-14 sm:py-16">
    <div class="container-page">
      <div class="grid gap-4 md:grid-cols-3">
        {
          solutionStats.map((item) => {
            const Icon = item.icon;

            return (
              <div class="group rounded-[2rem] border border-brand-border bg-card p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-brand-green hover:shadow-xl">
                <div class="flex items-center gap-4">
                  <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green transition duration-300 group-hover:bg-brand-green group-hover:text-white">
                    <Icon className="size-6" />
                  </div>

                  <div>
                    <p class="text-xs font-black uppercase tracking-[0.2em] text-brand-muted">
                      {item.label}
                    </p>
                    <p class="mt-1 text-xl font-black text-brand-navy">
                      {item.value}
                    </p>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="bg-brand-card py-16 sm:py-20 lg:py-24">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <SectionHeading
          eyebrow="Solution Range"
          title="Complete plant solution categories"
          description="Browse plant solution pages prepared from the catalogue content, including process sections, machinery connections and support details."
        />

        <div class="rounded-[2rem] border border-brand-border bg-white p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
              <Factory className="size-6" />
            </div>

            <div>
              <h2 class="text-xl font-black text-brand-navy">
                Catalogue-based solution pages
              </h2>
              <p class="mt-2 text-sm leading-7 text-brand-muted">
                Each solution page includes available overview content, process sections,
                plant details and related machinery references.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          solutions.map((solution) => (
            <SolutionCard solution={solution} />
          ))
        }

        <article class="group relative grid h-full overflow-hidden rounded-[2rem] border border-dashed border-brand-green/45 bg-white/70 p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-brand-green hover:bg-white hover:shadow-xl">
          <div class="absolute right-0 top-0 size-32 translate-x-10 -translate-y-10 rounded-full bg-brand-green/10 transition duration-300 group-hover:scale-125"></div>

          <div class="relative flex min-h-[18rem] flex-col justify-between">
            <div>
              <div class="flex size-14 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green transition duration-300 group-hover:bg-brand-green group-hover:text-white">
                <Plus className="size-7" />
              </div>

              <p class="mt-6 text-sm font-black uppercase tracking-[0.22em] text-brand-green">
                Coming Soon
              </p>

              <h3 class="mt-3 text-2xl font-black leading-tight text-brand-navy">
                More plant solutions
              </h3>

              <p class="mt-4 text-sm leading-7 text-brand-muted">
                Additional solution categories can be added here when more catalogue
                content or client-provided service details are available.
              </p>
            </div>

            <div class="mt-8 inline-flex min-h-11 items-center text-sm font-black text-brand-green">
              <Sparkles className="mr-2 size-4" />
              Ready for expansion
              <ArrowRight className="ml-2 size-4 transition duration-300 group-hover:translate-x-1" />
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <CTASection
    title="Discuss plant solution requirements"
    description="Share plant capacity, raw material, process or machinery requirement through the inquiry page."
  />
</BaseLayout>