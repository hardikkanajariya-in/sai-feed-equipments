---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionHeading from "@/components/site/SectionHeading.astro";
import FeatureList from "@/components/site/FeatureList.astro";
import SpecFields from "@/components/site/SpecFields.astro";
import ProductCard from "@/components/site/ProductCard.astro";
import CTASection from "@/components/site/CTASection.astro";
import { products, getProduct, getRelatedProducts } from "@/data/products";
import {
  ArrowRight,
  BadgeCheck,
  BookOpenText,
  FileText,
  Layers,
  ListChecks,
  Settings,
} from "lucide-react";

export function getStaticPaths() {
  return products.map((product) => ({
    params: {
      slug: product.slug,
    },
  }));
}

const { slug } = Astro.params;
const product = getProduct(slug ?? "");

if (!product) {
  return Astro.redirect("/products");
}

const relatedProducts = getRelatedProducts(product.related).slice(0, 3);

const hasFeatures = Boolean(product.features?.length);
const hasSections = Boolean(product.sections?.length);
const hasApplications = Boolean(product.applications?.length);
const hasSpecTables = Boolean(product.specTables?.length);
const hasSpecColumns = Boolean(product.specColumns?.length);
const hasSpecifications = hasSpecTables || hasSpecColumns;
const hasRelatedProducts = relatedProducts.length > 0;
---
<BaseLayout
  title={product.title}
  description={product.summary}
  image={product.image}
>
  <PageHero
    eyebrow="Product"
    title={product.title}
    description={product.summary}
    image={product.image}
    imageAlt={product.imageAlt}
  />

  <section class="section-shell bg-background py-16 sm:py-20 lg:py-24">
    <div class="container-page">
      <div class="grid gap-12 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
        <div class="lg:sticky lg:top-28" data-reveal="left">
          <SectionHeading
            eyebrow="Overview"
            title={`${product.title} details`}
            description={product.summary}
          />

          <div class="surface-card mt-8 hidden p-6 lg:block">
            <div class="flex items-start gap-4">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
                <BookOpenText className="size-6" />
              </div>

              <div>
                <h2 class="text-xl font-black text-brand-navy">
                  Product information
                </h2>
                <p class="mt-2 text-sm leading-7 text-brand-muted">
                  Product details, features and technical data are structured from the Sai Feed Equipment catalogue.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div data-reveal="right">
          {
            hasFeatures ? (
              <div class="surface-card p-6 sm:p-8">
                <div class="mb-6 flex items-start gap-4">
                  <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
                    <ListChecks className="size-6" />
                  </div>

                  <div>
                    <p class="text-sm font-black uppercase tracking-[0.22em] text-brand-green">
                      Key Features
                    </p>
                    <h2 class="mt-2 text-2xl font-black text-brand-navy">
                      Main product highlights
                    </h2>
                  </div>
                </div>

                <FeatureList items={product.features} />
              </div>
            ) : (
              <div class="surface-card p-6 sm:p-8">
                <div class="flex items-start gap-4">
                  <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
                    <FileText className="size-6" />
                  </div>

                  <div>
                    <h2 class="text-2xl font-black text-brand-navy">
                      Product details
                    </h2>
                    <p class="mt-3 text-sm leading-7 text-brand-muted">
                      Product information is available through the catalogue and inquiry contact.
                    </p>
                  </div>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>

  {
    hasSections && (
      <section class="section-shell bg-brand-card py-16 sm:py-20 lg:py-24">
        <div class="container-page">
          <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
            <SectionHeading
              eyebrow="Details"
              title="Catalogue sections"
              description="Additional product details, process notes and catalogue points related to this product."
            />

            <div class="surface-card rounded-[2rem] p-6" data-reveal="right">
              <div class="flex items-start gap-4">
                <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
                  <Layers className="size-6" />
                </div>

                <div>
                  <h2 class="text-xl font-black text-brand-navy">
                    Structured product information
                  </h2>
                  <p class="mt-2 text-sm leading-7 text-brand-muted">
                    Catalogue content is grouped into readable technical sections.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="surface-card mt-12 divide-y divide-brand-border overflow-hidden">
            {
              product.sections?.map((section, index) => (
                <article class="grid gap-6 p-6 sm:p-8 lg:grid-cols-[0.38fr_0.62fr] lg:gap-10" data-reveal="up">
                  <div>
                    <div class="inline-flex size-12 items-center justify-center rounded-2xl bg-brand-green/10 text-sm font-black text-brand-green">
                      {String(index + 1).padStart(2, "0")}
                    </div>

                    <h2 class="mt-5 text-2xl font-black text-brand-navy">
                      {section.title}
                    </h2>
                  </div>

                  <div>
                    <FeatureList items={section.items} columns={1} variant="line" />
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    )
  }

  {
    (hasApplications || hasSpecifications) && (
      <section class="section-shell bg-background py-16 sm:py-20 lg:py-24">
        <div class="container-page">
          <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
            <div class="lg:sticky lg:top-28" data-reveal="left">
              <SectionHeading
                eyebrow="Technical Scope"
                title={hasApplications ? "Applications and specifications" : "Technical specifications"}
                description={
                  hasApplications
                    ? "Product applications and technical specification data from the catalogue."
                    : "Technical specification data from the catalogue."
                }
              />
            </div>

            <div class="grid gap-6">
              {
                hasApplications && (
                  <article class="surface-card p-6 sm:p-7" data-reveal="right">
                    <div class="mb-6 flex items-start gap-4">
                      <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
                        <BadgeCheck className="size-6" />
                      </div>

                      <div>
                        <p class="text-sm font-black uppercase tracking-[0.22em] text-brand-green">
                          Applications
                        </p>
                        <h2 class="mt-2 text-2xl font-black text-brand-navy">
                          Product use cases
                        </h2>
                      </div>
                    </div>

                    <FeatureList items={product.applications} columns={1} variant="compact" />
                  </article>
                )
              }

              {
                hasSpecifications && (
                  <SpecFields
                    columns={product.specColumns}
                    tables={product.specTables}
                  />
                )
              }
            </div>
          </div>
        </div>
      </section>
    )
  }

  {
    hasRelatedProducts && (
      <section class="section-shell bg-brand-card py-16 sm:py-20 lg:py-24">
        <div class="container-page">
          <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
            <SectionHeading
              eyebrow="Related"
              title="Related products"
              description="Explore related machinery and equipment from the Sai Feed Equipment product range."
            />

            <div class="surface-card rounded-[2rem] p-6" data-reveal="right">
              <div class="flex items-start gap-4">
                <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green">
                  <Settings className="size-6" />
                </div>

                <div>
                  <h2 class="text-xl font-black text-brand-navy">
                    More equipment options
                  </h2>
                  <p class="mt-2 text-sm leading-7 text-brand-muted">
                    Showing three related products to keep this section focused.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
            {
              relatedProducts.map((related) => (
                <ProductCard product={related} />
              ))
            }
          </div>

          <div class="mt-10 text-center">
            <a
              href="/products"
              class="group inline-flex min-h-12 items-center justify-center rounded-full border border-brand-border bg-white px-7 text-sm font-black text-brand-navy shadow-sm transition duration-300 hover:-translate-y-0.5 hover:border-brand-green hover:text-brand-green hover:shadow-lg"
            >
              Browse Product Range
              <ArrowRight className="ml-2 size-4 transition duration-300 group-hover:translate-x-1" />
            </a>
          </div>
        </div>
      </section>
    )
  }

  <CTASection
    title={`Send inquiry for ${product.title}`}
    description="Share the product requirement through phone, email or inquiry form."
  />
</BaseLayout>
