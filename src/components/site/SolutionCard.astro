---
import type { Solution } from "@/data/solutions";
import { ArrowRight, Factory, Layers } from "lucide-react";
import OptimizedPicture from "@/components/site/OptimizedPicture.astro";

interface Props {
  solution: Solution;
}

const { solution } = Astro.props;
---

<a
  href={`/solutions/${solution.slug}`}
  class="surface-card interactive-panel group relative grid h-full transition duration-300 hover:-translate-y-1 hover:border-brand-green hover:shadow-xl"
  data-reveal="zoom"
  data-tilt
>
  <div class="relative aspect-[16/10] overflow-hidden bg-white">
    <OptimizedPicture
      src={solution.image}
      alt={solution.imageAlt}
      width={900}
      height={560}
      loading="lazy"
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
      class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/75 via-brand-navy/10 to-transparent opacity-70 transition duration-300 group-hover:opacity-85"></div>

    <div class="absolute left-4 top-4 flex items-center gap-2 rounded-full border border-white/15 bg-brand-navy/70 px-3 py-2 text-xs font-black uppercase tracking-[0.16em] text-white shadow-lg backdrop-blur">
      <Layers className="size-3.5 text-brand-green" />
      Plant Solution
    </div>

    <div class="absolute right-4 top-4 flex size-10 translate-x-2 -translate-y-2 items-center justify-center rounded-full bg-white text-brand-navy opacity-0 shadow-lg transition duration-300 group-hover:translate-x-0 group-hover:translate-y-0 group-hover:opacity-100">
      <ArrowRight className="size-5" />
    </div>

    <div class="absolute bottom-0 left-0 right-0 p-5">
      <h3 class="text-2xl font-black leading-tight text-white">
        {solution.title}
      </h3>
    </div>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <div class="flex gap-4">
      <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green transition duration-300 group-hover:bg-brand-green group-hover:text-white">
        <Factory className="size-6" />
      </div>

      <div>
        <p class="line-clamp-4 text-sm leading-7 text-brand-muted">
          {solution.summary}
        </p>
      </div>
    </div>

    <div class="mt-auto pt-6">
      <span class="inline-flex min-h-11 items-center rounded-full bg-brand-green/10 px-5 text-sm font-black text-brand-green transition duration-300 group-hover:bg-brand-green group-hover:text-white">
        View Solution
        <ArrowRight className="ml-2 size-4 transition duration-300 group-hover:translate-x-1" />
      </span>
    </div>
  </div>
</a>
