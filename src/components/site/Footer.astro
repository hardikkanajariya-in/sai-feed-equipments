---
import { site } from "@/data/site";
import { products } from "@/data/products";
import { solutions } from "@/data/solutions";
import {
  ArrowRight,
  Mail,
  MapPin,
  Phone,
  Globe,
  Factory,
  Leaf,
} from "lucide-react";

const year = new Date().getFullYear();

const primaryProducts = products.slice(0, 7);

const phoneHref = site.phones?.[0]
  ? `tel:${site.phones[0].replaceAll("-", "").replaceAll(" ", "")}`
  : "/contact";
---

<footer class="relative overflow-hidden bg-brand-navy text-white">
  <div class="pointer-events-none absolute inset-0 opacity-25">
    <div class="absolute -left-32 top-10 size-80 rounded-full bg-brand-green blur-3xl"></div>
    <div class="absolute -right-32 bottom-0 size-96 rounded-full bg-brand-steel blur-3xl"></div>
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:56px_56px]"
    >
    </div>
  </div>

  <div class="container-page relative py-12 sm:py-14 lg:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.25fr_0.8fr_0.8fr_1.15fr]">
      <div>
        <a href="/" class="group inline-flex items-center" aria-label="Sai Feed Equipment Home">
          <img
            src="/images/logo.png"
            alt="Sai Feed Equipment"
            width="170"
            height="84"
            class="h-16 w-auto rounded-xl bg-white/95 p-2 object-contain transition duration-300 group-hover:scale-[1.03]"
          />
        </a>

        <p class="mt-6 max-w-sm text-sm leading-7 text-white/65">
          {site.backCoverTagline}
        </p>

        <div class="mt-6 grid gap-3">
          {
            site.footerMessages.map((message) => (
              <div class="flex gap-3 text-sm leading-6 text-white/65">
                <Leaf className="mt-1 size-4 shrink-0 text-brand-green" />
                <p>{message}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="flex items-center gap-2 text-sm font-black uppercase tracking-[0.2em] text-white/85">
          <Factory className="size-4 text-brand-green" />
          Products
        </h3>

        <div class="mt-5 grid gap-2">
          {
            primaryProducts.map((product) => (
              <a
                href={`/products/${product.slug}`}
                class="group flex min-h-9 items-center justify-between rounded-xl px-0 text-sm font-semibold text-white/65 transition duration-300 hover:px-3 hover:text-white"
              >
                <span>{product.title}</span>
                <ArrowRight className="size-3.5 opacity-0 transition duration-300 group-hover:translate-x-1 group-hover:opacity-100" />
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="flex items-center gap-2 text-sm font-black uppercase tracking-[0.2em] text-white/85">
          <Leaf className="size-4 text-brand-green" />
          Solutions
        </h3>

        <div class="mt-5 grid gap-2">
          {
            solutions.map((solution) => (
              <a
                href={`/solutions/${solution.slug}`}
                class="group flex min-h-9 items-center justify-between rounded-xl px-0 text-sm font-semibold text-white/65 transition duration-300 hover:px-3 hover:text-white"
              >
                <span>{solution.title}</span>
                <ArrowRight className="size-3.5 opacity-0 transition duration-300 group-hover:translate-x-1 group-hover:opacity-100" />
              </a>
            ))
          }

          <a
            href="/gallery"
            class="group flex min-h-9 items-center justify-between rounded-xl px-0 text-sm font-semibold text-white/65 transition duration-300 hover:px-3 hover:text-white"
          >
            <span>Gallery</span>
            <ArrowRight className="size-3.5 opacity-0 transition duration-300 group-hover:translate-x-1 group-hover:opacity-100" />
          </a>

          <a
            href="/about"
            class="group flex min-h-9 items-center justify-between rounded-xl px-0 text-sm font-semibold text-white/65 transition duration-300 hover:px-3 hover:text-white"
          >
            <span>About</span>
            <ArrowRight className="size-3.5 opacity-0 transition duration-300 group-hover:translate-x-1 group-hover:opacity-100" />
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-black uppercase tracking-[0.2em] text-white/85">
          Contact
        </h3>

        <div class="mt-5 grid gap-3 text-sm leading-6 text-white/65">
          <div class="flex gap-3">
            <MapPin className="mt-1 size-4 shrink-0 text-brand-green" />
            <p>{site.addressLines.join(", ")}</p>
          </div>

          <a
            href={`mailto:${site.email}`}
            class="group flex min-h-10 items-center gap-3 rounded-xl transition duration-300 hover:text-white"
          >
            <Mail className="size-4 shrink-0 text-brand-green" />
            <span class="break-all">{site.email}</span>
          </a>

          {
            site.phones.map((phone) => (
              <a
                href={`tel:${phone.replaceAll("-", "").replaceAll(" ", "")}`}
                class="group flex min-h-10 items-center gap-3 rounded-xl transition duration-300 hover:text-white"
              >
                <Phone className="size-4 shrink-0 text-brand-green" />
                <span>{phone}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <div
      class="container-page flex flex-col gap-3 py-5 text-xs text-white/55 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <a
        href={site.websiteUrl}
        target="_blank"
        rel="noreferrer"
        class="transition hover:text-white"
      >
        {site.website}
      </a>
    </div>
  </div>
</footer>