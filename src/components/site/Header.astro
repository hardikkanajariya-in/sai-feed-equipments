---
import { site } from "@/data/site";
import { products } from "@/data/products";
import { solutions } from "@/data/solutions";
import {
  ArrowRight,
  ChevronDown,
  Menu,
  Phone,
} from "lucide-react";

const mainNav = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Gallery", href: "/gallery" },
];

const phoneHref = site.phones?.[0]
  ? `tel:${site.phones[0].replaceAll("-", "").replaceAll(" ", "")}`
  : "/contact";
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-navy/95 text-white shadow-lg shadow-black/10 backdrop-blur-xl">
  <div class="container-page flex min-h-[4.75rem] items-center justify-between gap-4">
    <!-- Logo -->
    <a
      href="/"
      class="group flex min-h-14 items-center"
      aria-label="Sai Feed Equipment Home"
    >
      <img
        src="/images/logo.png"
        alt="Sai Feed Equipment"
        width="160"
        height="78"
        class="h-12 w-auto object-contain transition duration-300 group-hover:scale-[1.04] sm:h-14"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            class="group relative inline-flex min-h-11 items-center rounded-full px-4 text-sm font-semibold text-white/75 transition duration-300 hover:bg-white/10 hover:text-white"
          >
            <span>{item.label}</span>
            <span class="absolute bottom-2 left-4 h-0.5 w-0 rounded-full bg-brand-green transition-all duration-300 group-hover:w-[calc(100%-2rem)]" />
          </a>
        ))
      }

      <!-- Products Hover Dropdown -->
      <div class="group relative">
        <a
          href="/products"
          class="relative inline-flex min-h-11 items-center gap-2 rounded-full px-4 text-sm font-semibold text-white/75 transition duration-300 hover:bg-white/10 hover:text-white"
        >
          <span>Products</span>
          <ChevronDown className="size-3.5 transition duration-300 group-hover:rotate-180" />
          <span class="absolute bottom-2 left-4 h-0.5 w-0 rounded-full bg-brand-green transition-all duration-300 group-hover:w-[calc(100%-2rem)]" />
        </a>

        <div class="pointer-events-none invisible absolute left-1/2 top-12 z-50 w-[44rem] -translate-x-1/2 translate-y-3 pt-3 opacity-0 transition duration-300 group-hover:pointer-events-auto group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
          <div class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-brand-navy shadow-2xl shadow-black/30 ring-1 ring-white/5">
            <div class="border-b border-white/10 bg-white/[0.03] px-5 py-4">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="text-xs font-black uppercase tracking-[0.25em] text-brand-green">
                    Product Range
                  </p>
                  <p class="mt-1 text-sm text-white/60">
                    Feed plant machinery, automation and spare equipment.
                  </p>
                </div>

                <a
                  href="/products"
                  class="group/all inline-flex shrink-0 items-center rounded-full bg-brand-green/10 px-4 py-2 text-xs font-black uppercase tracking-[0.16em] text-brand-green transition duration-300 hover:bg-brand-green hover:text-white"
                >
                  View All
                  <ArrowRight className="ml-2 size-3.5 transition duration-300 group-hover/all:translate-x-1" />
                </a>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-2 p-3">
              {
                products.map((product) => (
                  <a
                    href={`/products/${product.slug}`}
                    class="group/item rounded-2xl border border-transparent px-4 py-3 transition duration-300 hover:-translate-y-0.5 hover:border-white/10 hover:bg-white/10"
                  >
                    <span class="flex items-center justify-between gap-4">
                      <span class="text-sm font-bold text-white/80 transition group-hover/item:text-white">
                        {product.title}
                      </span>
                      <ArrowRight className="size-4 text-brand-green opacity-0 transition duration-300 group-hover/item:translate-x-1 group-hover/item:opacity-100" />
                    </span>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Solutions Hover Dropdown -->
      <div class="group relative">
        <a
          href="/solutions"
          class="relative inline-flex min-h-11 items-center gap-2 rounded-full px-4 text-sm font-semibold text-white/75 transition duration-300 hover:bg-white/10 hover:text-white"
        >
          <span>Solutions</span>
          <ChevronDown className="size-3.5 transition duration-300 group-hover:rotate-180" />
          <span class="absolute bottom-2 left-4 h-0.5 w-0 rounded-full bg-brand-green transition-all duration-300 group-hover:w-[calc(100%-2rem)]" />
        </a>

        <div class="pointer-events-none invisible absolute left-1/2 top-12 z-50 w-96 -translate-x-1/2 translate-y-3 pt-3 opacity-0 transition duration-300 group-hover:pointer-events-auto group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
          <div class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-brand-navy shadow-2xl shadow-black/30 ring-1 ring-white/5">
            <div class="border-b border-white/10 bg-white/[0.03] px-5 py-4">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="text-xs font-black uppercase tracking-[0.25em] text-brand-green">
                    Plant Solutions
                  </p>
                  <p class="mt-1 text-sm text-white/60">
                    Complete industrial plant categories.
                  </p>
                </div>

                <a
                  href="/solutions"
                  class="group/all inline-flex shrink-0 items-center rounded-full bg-brand-green/10 px-4 py-2 text-xs font-black uppercase tracking-[0.16em] text-brand-green transition duration-300 hover:bg-brand-green hover:text-white"
                >
                  View All
                  <ArrowRight className="ml-2 size-3.5 transition duration-300 group-hover/all:translate-x-1" />
                </a>
              </div>
            </div>

            <div class="grid gap-2 p-3">
              {
                solutions.map((solution) => (
                  <a
                    href={`/solutions/${solution.slug}`}
                    class="group/item rounded-2xl border border-transparent px-4 py-3 transition duration-300 hover:-translate-y-0.5 hover:border-white/10 hover:bg-white/10"
                  >
                    <span class="flex items-center justify-between gap-4">
                      <span class="text-sm font-bold text-white/80 transition group-hover/item:text-white">
                        {solution.title}
                      </span>
                      <ArrowRight className="size-4 text-brand-green opacity-0 transition duration-300 group-hover/item:translate-x-1 group-hover/item:opacity-100" />
                    </span>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Desktop Actions -->
    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={phoneHref}
        class="group inline-flex min-h-11 items-center justify-center gap-2 overflow-hidden rounded-full border border-white/15 px-5 text-sm font-bold text-white transition duration-300 hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/10"
      >
        <Phone className="size-4" />
        <span class="transition duration-300 group-hover:scale-105">Call Now</span>
      </a>

      <a
        href="/contact"
        class="group relative inline-flex min-h-11 items-center justify-center overflow-hidden rounded-full bg-brand-green px-5 text-sm font-bold text-white shadow-lg shadow-brand-green/20 transition duration-300 hover:-translate-y-0.5 hover:bg-brand-green-dark hover:shadow-brand-green/30"
      >
        <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/25 to-transparent transition duration-700 group-hover:translate-x-full" />
        <span class="relative">Send Inquiry</span>
      </a>
    </div>

    <!-- Mobile Menu -->
    <details class="group/mobile relative lg:hidden" data-mobile-dropdown>
      <summary
        class="flex min-h-12 min-w-12 cursor-pointer list-none items-center justify-center rounded-2xl border border-white/15 text-white transition duration-300 hover:bg-white/10"
        aria-label="Open menu"
      >
        <Menu className="size-6 transition duration-300 group-open/mobile:rotate-90" />
      </summary>

      <div class="pointer-events-none invisible absolute right-0 top-16 max-h-[calc(100vh-6rem)] w-[min(23rem,calc(100vw-2rem))] translate-y-3 overflow-y-auto rounded-[1.5rem] border border-white/10 bg-brand-navy opacity-0 shadow-2xl shadow-black/30 ring-1 ring-white/5 transition duration-300 group-open/mobile:pointer-events-auto group-open/mobile:visible group-open/mobile:translate-y-0 group-open/mobile:opacity-100">
        <nav class="grid p-3" aria-label="Mobile navigation">
          {
            mainNav.map((item) => (
              <a
                href={item.href}
                class="flex min-h-12 items-center rounded-2xl px-4 text-sm font-bold text-white/80 transition duration-300 hover:bg-white/10 hover:text-white"
              >
                {item.label}
              </a>
            ))
          }

          <div class="my-3 h-px bg-white/10" />

          <a
            href="/products"
            class="flex min-h-12 items-center justify-between rounded-2xl px-4 text-sm font-black uppercase tracking-[0.18em] text-brand-green transition duration-300 hover:bg-white/10"
          >
            <span>Products</span>
            <ArrowRight className="size-4" />
          </a>

          {
            products.map((product) => (
              <a
                href={`/products/${product.slug}`}
                class="flex min-h-11 items-center justify-between rounded-2xl px-4 text-sm font-semibold text-white/70 transition duration-300 hover:bg-white/10 hover:text-white"
              >
                <span>{product.title}</span>
                <ArrowRight className="size-4 text-brand-green" />
              </a>
            ))
          }

          <div class="my-3 h-px bg-white/10" />

          <a
            href="/solutions"
            class="flex min-h-12 items-center justify-between rounded-2xl px-4 text-sm font-black uppercase tracking-[0.18em] text-brand-green transition duration-300 hover:bg-white/10"
          >
            <span>Solutions</span>
            <ArrowRight className="size-4" />
          </a>

          {
            solutions.map((solution) => (
              <a
                href={`/solutions/${solution.slug}`}
                class="flex min-h-11 items-center justify-between rounded-2xl px-4 text-sm font-semibold text-white/70 transition duration-300 hover:bg-white/10 hover:text-white"
              >
                <span>{solution.title}</span>
                <ArrowRight className="size-4 text-brand-green" />
              </a>
            ))
          }

          <div class="my-3 h-px bg-white/10" />

          <a
            href={phoneHref}
            class="mb-2 flex min-h-12 items-center justify-center gap-2 rounded-2xl border border-white/15 px-4 text-sm font-bold text-white transition duration-300 hover:bg-white/10"
          >
            <Phone className="size-4" />
            Call Now
          </a>

          <a
            href="/contact"
            class="flex min-h-12 items-center justify-center rounded-2xl bg-brand-green px-4 text-sm font-black text-white transition duration-300 hover:bg-brand-green-dark"
          >
            Send Inquiry
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>

<script>
  const mobileDropdowns = document.querySelectorAll<HTMLDetailsElement>("[data-mobile-dropdown]");

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;

    mobileDropdowns.forEach((dropdown) => {
      if (!dropdown.contains(target)) {
        dropdown.open = false;
      }
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;

    mobileDropdowns.forEach((dropdown) => {
      dropdown.open = false;
    });
  });
</script>