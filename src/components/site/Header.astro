---
const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Products", href: "/products/pellet-mill" },
  { label: "Solutions", href: "/solutions/animal-feed-plant" },
  { label: "Gallery", href: "/gallery" },
  { label: "Contact", href: "/contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-navy text-white">
  <div class="container-page flex min-h-16 items-center justify-between gap-4">
    <a href="/" class="flex min-h-11 items-center gap-3">
      <span
        class="flex size-10 shrink-0 items-center justify-center rounded-full bg-brand-green text-sm font-black text-white"
      >
        SFE
      </span>

      <span class="leading-tight">
        <span class="block text-sm font-black tracking-wide sm:text-base">
          Sai Feed Equipment
        </span>
        <span class="hidden text-xs font-medium text-white/60 sm:block">
          Feed Plant & Pellet Machinery
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold text-white/75 transition hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href="tel:"
        class="inline-flex min-h-11 items-center justify-center rounded-full border border-white/15 px-5 text-sm font-bold text-white transition hover:bg-white/10"
      >
        Call Now
      </a>

      <a
        href="/contact"
        class="inline-flex min-h-11 items-center justify-center rounded-full bg-brand-green px-5 text-sm font-bold text-white shadow-lg shadow-brand-green/20 transition hover:bg-brand-green-dark"
      >
        Send Inquiry
      </a>
    </div>

    <details class="relative lg:hidden">
      <summary
        class="flex min-h-11 min-w-11 cursor-pointer list-none items-center justify-center rounded-xl border border-white/15 text-xl text-white"
        aria-label="Open menu"
      >
        ☰
      </summary>

      <div
        class="absolute right-0 top-14 w-[min(20rem,calc(100vw-2rem))] overflow-hidden rounded-2xl border border-white/10 bg-brand-navy shadow-2xl"
      >
        <nav class="grid p-2" aria-label="Mobile navigation">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="flex min-h-12 items-center rounded-xl px-4 text-sm font-semibold text-white/80 transition hover:bg-white/10 hover:text-white"
              >
                {item.label}
              </a>
            ))
          }

          <a
            href="/contact"
            class="mt-2 flex min-h-12 items-center justify-center rounded-xl bg-brand-green px-4 text-sm font-bold text-white"
          >
            Send Inquiry
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>