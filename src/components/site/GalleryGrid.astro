---
import type { GalleryItem } from "@/data/gallery";
import { ArrowUpRight } from "lucide-react";
import OptimizedPicture from "@/components/site/OptimizedPicture.astro";

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;

// Extract unique categories for filter tabs
const categories = ["All", "Plant", "Product", "Automation", "Dies & Rolls", "Material Handling"];
---

<!-- Premium Glassmorphic Filters -->
<div class="flex flex-wrap items-center justify-center gap-3 mb-10" id="gallery-filters">
  {
    categories.map((category) => (
      <button
        data-filter={category}
        class:list={[
          "relative px-5 py-3 rounded-full text-xs font-black uppercase tracking-[0.18em] transition-all duration-300 border backdrop-blur-md cursor-pointer select-none",
          category === "All"
            ? "bg-brand-green text-white border-brand-green shadow-lg shadow-brand-green/20"
            : "bg-white/60 dark:bg-brand-navy/30 text-brand-navy dark:text-white border-brand-border/40 hover:border-brand-green hover:text-brand-green hover:shadow-md",
        ]}
      >
        {category}
      </button>
    ))
  }
</div>

<!-- Masonry Bento Grid Layout (using CSS Columns to eliminate empty vertical gaps) -->
<div class="columns-1 sm:columns-2 lg:columns-3 gap-6 [column-fill:_balance] w-full transition-all duration-500" id="gallery-grid" data-stagger>
  {
    items.map((item, index) => {
      return (
        <figure
          class="break-inside-avoid mb-6 surface-card interactive-panel group relative flex flex-col transition-all duration-500 hover:-translate-y-1.5 hover:border-brand-green hover:shadow-2xl overflow-hidden rounded-[2rem] bg-white h-fit w-full"
          data-tilt
          data-gallery-item
          data-category={item.category}
        >
          <!-- Image Section (Natural aspect ratio, no forced cropping) -->
          <div class="relative overflow-hidden bg-white w-full">
            <OptimizedPicture
              src={item.image}
              alt={item.alt}
              width={640}
              height={480}
              loading={index < 3 ? "eager" : "lazy"}
              fetchpriority={index < 2 ? "high" : "auto"}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              class="w-full h-auto block transition duration-700 group-hover:scale-103"
            />
          </div>

          <!-- Content Section Below Image -->
          <div class="p-6 bg-gradient-to-b from-white to-brand-card dark:from-brand-navy/95 dark:to-brand-navy border-t border-brand-border/20 flex-1 flex flex-col justify-between">
            <figcaption>
              <h3 class="text-lg sm:text-xl font-black leading-tight text-brand-navy dark:text-white group-hover:text-brand-green transition duration-300">
                {item.title}
              </h3>

              <p class="mt-2 text-xs sm:text-sm leading-relaxed text-brand-muted">
                {item.alt}
              </p>
            </figcaption>

            <div class="mt-4 flex items-center justify-end">
              <span class="text-xs font-black uppercase tracking-[0.12em] text-brand-green flex items-center gap-1 group-hover:translate-x-1 transition duration-300">
                View Details <ArrowUpRight className="size-4" />
              </span>
            </div>
          </div>
        </figure>
      );
    })
  }
</div>

<script>
  function initGalleryFilters() {
    const filtersContainer = document.getElementById("gallery-filters");
    if (!filtersContainer) return;

    const filterButtons = filtersContainer.querySelectorAll("[data-filter]");
    const galleryItems = document.querySelectorAll("[data-gallery-item]");

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-filter");

        // Update active button styles
        filterButtons.forEach((b) => {
          b.classList.remove(
            "bg-brand-green",
            "text-white",
            "border-brand-green",
            "shadow-lg",
            "shadow-brand-green/20"
          );
          b.classList.add(
            "bg-white/60",
            "dark:bg-brand-navy/30",
            "text-brand-navy",
            "dark:text-white",
            "border-brand-border/40"
          );
        });

        btn.classList.add(
          "bg-brand-green",
          "text-white",
          "border-brand-green",
          "shadow-lg",
          "shadow-brand-green/20"
        );
        btn.classList.remove(
          "bg-white/60",
          "dark:bg-brand-navy/30",
          "text-brand-navy",
          "dark:text-white",
          "border-brand-border/40"
        );

        // Animate grid items out
        galleryItems.forEach((item) => {
          item.classList.add("opacity-0", "scale-95");
        });

        // After a brief delay to allow fade-out, toggle visibility and fade-in
        setTimeout(() => {
          galleryItems.forEach((item) => {
            const itemCategory = item.getAttribute("data-category");
            const matches = category === "All" || itemCategory === category;

            if (matches) {
              item.classList.remove("hidden");
              // Force a layout reflow to ensure the transition runs correctly
              void (item as HTMLElement).offsetHeight;
              
              requestAnimationFrame(() => {
                item.classList.remove("opacity-0", "scale-95");
              });
            } else {
              item.classList.add("hidden");
            }
          });
        }, 200);
      });
    });
  }

  // Run on initial load
  initGalleryFilters();

  // Run on page transition (Astro View Transitions compatibility)
  document.addEventListener("astro:after-swap", initGalleryFilters);
</script>
