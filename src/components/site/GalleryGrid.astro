---
import type { GalleryItem } from "@/data/gallery";
import { ArrowUpRight, Image as ImageIcon } from "lucide-react";

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
  {
    items.map((item, index) => (
      <figure
        class:list={[
          "group relative overflow-hidden rounded-[2rem] border border-brand-border bg-card shadow-sm transition duration-300 hover:-translate-y-1 hover:border-brand-green hover:shadow-xl",
          index === 0 ? "lg:col-span-2" : "",
        ]}
      >
        <div
          class:list={[
            "relative overflow-hidden bg-white",
            index === 0 ? "aspect-[16/9]" : "aspect-[4/3]",
          ]}
        >
          <img
            src={item.image}
            alt={item.alt}
            width={index === 0 ? "1280" : "640"}
            height={index === 0 ? "720" : "480"}
            loading={index < 3 ? "eager" : "lazy"}
            decoding="async"
            class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
          />

          <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/80 via-brand-navy/10 to-transparent opacity-80 transition duration-300 group-hover:opacity-90"></div>

          <div class="absolute left-4 top-4 flex items-center gap-2 rounded-full border border-white/15 bg-brand-navy/70 px-3 py-2 text-xs font-black uppercase tracking-[0.16em] text-white shadow-lg backdrop-blur">
            <ImageIcon className="size-3.5 text-brand-green" />
            {item.category}
          </div>

          <div class="absolute bottom-0 left-0 right-0 p-5">
            <figcaption>
              <h3 class="text-xl font-black leading-tight text-white">
                {item.title}
              </h3>

              <p class="mt-2 line-clamp-2 text-sm leading-6 text-white/70">
                {item.alt}
              </p>
            </figcaption>
          </div>

          <div class="absolute right-4 top-4 flex size-10 translate-x-2 -translate-y-2 items-center justify-center rounded-full bg-white text-brand-navy opacity-0 shadow-lg transition duration-300 group-hover:translate-x-0 group-hover:translate-y-0 group-hover:opacity-100">
            <ArrowUpRight className="size-5" />
          </div>
        </div>
      </figure>
    ))
  }
</div>