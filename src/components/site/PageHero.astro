---
import OptimizedPicture from "@/components/site/OptimizedPicture.astro";

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  image,
  imageAlt = title,
  align = image ? "left" : "center",
} = Astro.props;

const hasImage = Boolean(image);
---

<section class="section-shell section-shell--dark relative overflow-hidden bg-brand-navy text-white">
  <div class="absolute inset-0 opacity-35">
    <div
      class="absolute -left-32 top-10 size-80 rounded-full bg-brand-green blur-3xl"
    >
    </div>
    <div
      class="absolute -right-32 bottom-0 size-96 rounded-full bg-brand-steel blur-3xl"
    >
    </div>
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:56px_56px]"
    >
    </div>
  </div>

  {
    hasImage ? (
      <div class="container-page relative grid min-h-[52svh] gap-10 py-14 sm:py-16 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div data-reveal="left">
          <div class="inline-flex items-center gap-3 rounded-full border border-brand-green/25 bg-brand-green/10 px-4 py-2 text-sm font-black uppercase tracking-[0.22em] text-brand-green shadow-sm shadow-brand-green/10 backdrop-blur">
            <span class="size-2 rounded-full bg-brand-green shadow-[0_0_18px_rgba(0,166,81,0.8)]" />
            <span>{eyebrow}</span>
          </div>

          <h1 class="mt-4 max-w-4xl text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl">
            {title}
          </h1>

          {description && (
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/70 sm:text-lg">
              {description}
            </p>
          )}
        </div>

        <div class="relative float-soft" data-reveal="right">
          <div class="absolute -inset-4 rounded-[2.5rem] bg-brand-green/15 blur-2xl" />

          <div class="surface-card-dark interactive-panel relative p-3" data-tilt>
            <OptimizedPicture
              src={image}
              alt={imageAlt}
              width={1000}
              height={720}
              loading="eager"
              fetchpriority="high"
              sizes="(max-width: 1024px) 100vw, 48vw"
              class="aspect-[16/10] h-full w-full rounded-[1.5rem] object-cover"
            />

            <div class="pointer-events-none absolute inset-3 rounded-[1.5rem] bg-gradient-to-t from-brand-navy/25 via-transparent to-transparent" />
          </div>
        </div>
      </div>
    ) : (
      <div
        class:list={[
          "container-page relative flex min-h-[46svh] items-center py-14 sm:py-16",
          align === "center"
            ? "justify-center text-center"
            : "justify-start text-left",
        ]}
      >
        <div
        class:list={[
            "",
            align === "center" ? "mx-auto max-w-4xl" : "max-w-4xl",
          ]}
          data-reveal="up"
        >
          <div class="inline-flex items-center gap-3 rounded-full border border-brand-green/25 bg-brand-green/10 px-4 py-2 text-sm font-black uppercase tracking-[0.22em] text-brand-green shadow-sm shadow-brand-green/10 backdrop-blur">
            <span class="size-2 rounded-full bg-brand-green shadow-[0_0_18px_rgba(0,166,81,0.8)]" />
            <span>{eyebrow}</span>
          </div>

          <h1 class="mt-4 text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl">
            {title}
          </h1>

          {description && (
            <p
              class:list={[
                "mt-6 text-base leading-8 text-white/70 sm:text-lg",
                align === "center" ? "mx-auto max-w-2xl" : "max-w-2xl",
              ]}
            >
              {description}
            </p>
          )}
        </div>
      </div>
    )
  }
</section>
