---
import { CheckCircle2 } from "lucide-react";

interface Props {
  items?: string[];
  columns?: 1 | 2;
  variant?: "card" | "line" | "compact";
}

const {
  items = [],
  columns = 2,
  variant = "card",
} = Astro.props;

const gridClass = columns === 1 ? "grid gap-3" : "grid gap-3 md:grid-cols-2";
---

{
  items.length > 0 && (
    <ul class={gridClass}>
      {
        items.map((item) => (
          <li
            class:list={[
              "group flex gap-3 text-sm leading-7 text-brand-muted transition duration-300",
              variant === "card" &&
                "rounded-2xl border border-brand-border bg-card p-4 shadow-sm hover:-translate-y-0.5 hover:border-brand-green hover:shadow-md",
              variant === "line" &&
                "border-b border-brand-border pb-4 last:border-b-0",
              variant === "compact" &&
                "rounded-xl bg-brand-green/5 px-4 py-3",
            ]}
          >
            <span
              class:list={[
                "mt-1 flex size-5 shrink-0 items-center justify-center rounded-full text-brand-green transition duration-300",
                variant === "card" &&
                  "bg-brand-green/10 group-hover:bg-brand-green group-hover:text-white",
                variant === "line" && "bg-brand-green/10",
                variant === "compact" && "bg-white",
              ]}
            >
              <CheckCircle2 className="size-4" />
            </span>

            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  )
}