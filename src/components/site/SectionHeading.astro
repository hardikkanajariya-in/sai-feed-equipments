---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const isCenter = align === "center";
---

<div class={isCenter ? "mx-auto max-w-3xl text-center" : "max-w-3xl"}>
  {eyebrow && <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-green">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-black tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">{title}</h2>
  {description && <p class="mt-5 text-base leading-8 text-brand-muted sm:text-lg">{description}</p>}
</div>
